# --- Live scores (optional) ---
# Enables the LIVE score overlay on the Fixtures page using API-Football (api-sports.io).
# Get a free key at https://www.api-football.com/ (dashboard → "API Key"). Free plan = 100 requests/day.
# WITHOUT this key the app works exactly as before — scores come from the Google Sheet only.
API_FOOTBALL_KEY=

# Optional overrides (defaults shown). The World Cup competition id / season in API-Football:
# API_FOOTBALL_LEAGUE_ID=1
# API_FOOTBALL_SEASON=2026

# --- App ---
# Absolute base URL, used for metadata / share images. Set this on Vercel.
# NEXT_PUBLIC_APP_URL=https://your-domain.com
